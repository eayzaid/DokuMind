spring.application.name=PlatformGateway
spring.jpa.hibernate.ddl-auto=create-drop
spring.sql.init.mode=always
spring.jpa.defer-datasource-initialization=true

logging.level.org.hibernate.SQL=DEBUG
logging.level.org.hibernate.orm.jdbc.bind=TRACE

application.base_url = "/api"

application.secret.refresh_token = "refresh_token_secret_key_00000000000000000000000000000000000"
application.secret.access_token = "access_token_secret_key_00000000000000000000000000000000000"
application.expiration.access_token = 300
application.expiration.refresh_token = 604800

spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=example@gmail.com
spring.mail.password="password_example"
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

email.templates.welcome.subject=Welcome to our platform!
email.templates.welcome.bodyText=Your account has been created successfully. Your temporary password is below. Please change it after logging in.
email.templates.reset.subject=Password Reset Request
email.templates.reset.bodyText=Your password has been reset. Your new temporary password is below. Please change it after logging in.

